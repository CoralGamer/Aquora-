# ==========================================================
# AQUORA MOBILE - PROTOCOLO DE SEGURIDAD NPM (CIBERSEGURIDAD)
# ==========================================================

# 1. Bloquear la ejecución de scripts arbitrarios en la instalación de paquetes.
# Evita ataques de Ejecución de Código Remoto (RCE) de dependencias comprometidas o maliciosas.
ignore-scripts=true

# 2. Requerir verificación estricta de certificados SSL en descargas
strict-ssl=true

# 3. Forzar el uso y validación estricta de firmas SHA en el package-lock.json
package-lock=true
audit=true
